# Postgres connection string.
# Easiest: create a free DB at https://neon.tech and paste the pooled connection URL here.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional: path to a pre-downloaded NPPES CSV to skip auto-download.
# NPPES_CSV_PATH="/absolute/path/to/npidata_pfile_YYYYMMDD-YYYYMMDD.csv"

// Interva — national IR physician outreach funnel
//
// Milestone 1 schema: NPPES-derived canonical physician records.
// Later milestones add: Enrichment (source-tagged facts), Outreach (funnel state),
// OutreachEvent (append-only touches).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Canonical physician record, keyed by NPI. One row per active IR physician.
model Physician {
  npi              String   @id
  entityTypeCode   String   // "1" = individual, "2" = org. Ingest filters to "1".
  firstName        String?
  middleName       String?
  lastName         String?
  namePrefix       String?
  nameSuffix       String?
  credentials      String?  // "MD", "DO", "MD, PhD", etc. Free-text from NPPES.
  gender           String?  // "M", "F", or null/"U"

  soleProprietor   String?  // "Y"/"N"/"X"
  enumerationDate  DateTime?
  lastUpdatedDate  DateTime?
  deactivationDate DateTime?
  deactivationReason String?

  // Derived Medicare PUF signal (backfilled by scripts/derive-active-ir.ts).
  // All nullable until the PUF ingest + derivation has run.
  lastIrBillingYear   Int?
  totalIrServices     Int?     // sum of Tot_Srvcs across all IR Tier-1 CPTs
  totalIrBenes        Int?     // sum of Tot_Benes (suppressed rows counted as 0)
  distinctIrCpts      Int?     // count of distinct IR Tier-1 CPT codes billed
  activeIrCategories  String[] @default([])  // ["VASCULAR", "EMBOLIZATION", ...]
  isActiveIr          Boolean  @default(false)

  // Derived from PUF Place_Of_Srvc distribution (F=facility, O=office).
  // Office-share over IR services. Null when no PUF data.
  irOfficeServices    Int?     // services billed POS="O"
  irFacilityServices  Int?     // services billed POS="F"
  // "OBL" = >75% office  |  "FACILITY" = >75% facility  |  "MIXED" | null
  practiceSetting     String?

  // Derived from PhysicianAffiliation + Facility.kind. Backfilled by
  // scripts/derive-practice-setting.ts after affiliations ingest.
  hasHospitalAffiliation Boolean @default(false)
  hasAscAffiliation      Boolean @default(false)

  taxonomies       PhysicianTaxonomy[]
  addresses        PhysicianAddress[]
  procedures       ProcedureVolume[]
  affiliations     PhysicianAffiliation[]
  facts            Fact[]
  signals          OutreachSignal[]
  channels         ContactChannel[]
  persona          OutreachPersona?
  outreach         OutreachStage?
  actions          OutreachAction[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([lastName, firstName])
  @@index([deactivationDate])
  @@index([isActiveIr])
  @@index([lastIrBillingYear])
}

// --- Taxonomies (1..15 per physician in NPPES). Relational so we can filter
//     "all physicians with taxonomy X" efficiently.
model PhysicianTaxonomy {
  id           Int       @id @default(autoincrement())
  npi          String
  physician    Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  code         String    // e.g. "2085R0204X"
  name         String?   // e.g. "Vascular & Interventional Radiology"
  license      String?
  licenseState String?
  isPrimary    Boolean   @default(false)
  slot         Int       // 1..15, from NPPES column position

  @@unique([npi, slot])
  @@index([code])
}

// --- Addresses. NPPES includes mailing + practice location per provider;
//     later enrichment may add additional practice sites.
model PhysicianAddress {
  id         Int       @id @default(autoincrement())
  npi        String
  physician  Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  kind       String    // "mailing" | "practice"
  line1      String?
  line2      String?
  city       String?
  state      String?
  postalCode String?
  country    String?   @default("US")
  phone      String?
  fax        String?

  // Backfilled from Census ZCTA→County + OMB CBSA delineation by
  // scripts/backfill-metros.ts. Null when ZIP maps to no metro (rural).
  cbsaCode   String?   // e.g. "35620"
  cbsaName   String?   // e.g. "New York-Newark-Jersey City, NY-NJ-PA"
  cbsaType   String?   // "METRO" | "MICRO"

  @@index([npi, kind])
  @@index([state, city])
  @@index([cbsaCode])
}

// ============================================================
// ENRICHMENT LAYER — source-attributed facts + outreach context
// ============================================================

// --- Registry of every data source that produces Facts. Acts as the
//     authority for source display name, freshness rules, and base
//     confidence. Worker scripts upsert their own row.
model Source {
  key            String   @id      // e.g. "PRACTICE_WEBSITE_SCRAPE"
  displayName    String            // "Practice website (auto-scraped)"
  category       String            // "verified" | "inferred" | "scraped" | "user_entered" | "derived"
  baseConfidence Float             // 0..1 default
  freshnessHours Int      @default(720)  // re-fetch if older than this
  lastRunAt      DateTime?
  lastSuccessAt  DateTime?
  notes          String?

  facts          Fact[]
}

// --- Append-only fact: every enrichment value carries provenance.
//     Multiple Facts can exist per (npi, fieldPath); UI/queries pick the
//     "winning" one via confidence + recency.
model Fact {
  id          BigInt   @id @default(autoincrement())
  npi         String
  physician   Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  fieldPath   String   // dotted: "contact.email_direct" | "ownership.is_partner" | "academic.h_index" | "signal.recent_publication"
  value       Json     // typed by fieldPath consumer
  valueText   String?  // searchable lowercase render of value (when string-like)

  sourceKey   String
  source      Source   @relation(fields: [sourceKey], references: [key], onDelete: Cascade)
  sourceUrl   String?  // permalink to evidence page

  fetchedAt   DateTime @default(now())
  validUntil  DateTime?
  confidence  Float    // 0..1
  supersededById BigInt?

  signals     OutreachSignal[]
  channels    ContactChannel[]

  @@index([npi, fieldPath])
  @@index([fieldPath])
  @@index([sourceKey])
  @@index([fetchedAt])
}

// --- Append-only timestamped events used for "why now" outreach context.
//     Derived from Facts (a published-paper Fact spawns a PUBLISHED_PAPER signal).
model OutreachSignal {
  id           BigInt   @id @default(autoincrement())
  npi          String
  physician    Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  kind         String   // "PUBLISHED_PAPER" | "CONFERENCE_SPEAKER" | "WON_AWARD" | "OPENED_NEW_OBL" | "JOB_POSTED" | "VENDOR_CASE_FEATURED" | "OIG_EXCLUDED" | "ACTIVE_TRIAL_INVESTIGATOR"
  occurredAt   DateTime
  summary      String   // one-line human description
  payload      Json?
  expiresAt    DateTime?

  sourceFactId BigInt?
  sourceFact   Fact?    @relation(fields: [sourceFactId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())

  @@index([npi, occurredAt(sort: Desc)])
  @@index([kind, occurredAt(sort: Desc)])
}

// --- Verified channels for outbound outreach. Always source-attributed.
model ContactChannel {
  id           Int      @id @default(autoincrement())
  npi          String
  physician    Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  kind         String   // "email_direct" | "email_practice" | "phone_direct" | "phone_practice" | "linkedin" | "twitter" | "mailing"
  value        String
  isPreferred  Boolean  @default(false)
  verified     Boolean  @default(false)
  verifiedAt   DateTime?
  verifyMethod String?  // "smtp_probe" | "manual" | "domain_match"

  sourceFactId BigInt?
  sourceFact   Fact?    @relation(fields: [sourceFactId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([npi, kind, value])
  @@index([npi, kind])
}

// --- Computed outreach archetype + GTM hook line. Refreshed by
//     scripts/derive-persona.ts after enricher runs.
model OutreachPersona {
  npi              String   @id
  physician        Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  archetype        String   // "OBL_PARTNER_OWNER" | "ASC_PARTNER" | "ASC_EMPLOYEE" | "HOSPITAL_EMPLOYED" | "ACADEMIC_FACULTY" | "PE_OWNED" | "RETIRING" | "UNKNOWN"
  archetypeConfidence Float
  hookSummary      String   // 1-3 sentence Interva-tailored hook
  qualifyingFactIds BigInt[] @default([])
  disqualifiers    String[] @default([])

  computedAt       DateTime @default(now())

  @@index([archetype])
}

// --- Funnel state machine. One row per physician once they enter the funnel.
model OutreachStage {
  npi          String   @id
  physician    Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  stage        String   // "untouched" | "enriched" | "qualified" | "queued" | "contacted" | "engaged" | "meeting" | "won" | "lost" | "dnq"
  ownerId      String?
  enteredAt    DateTime @default(now())
  lastTouchAt  DateTime?
  nextActionAt DateTime?
  notes        String?

  @@index([stage, lastTouchAt])
  @@index([ownerId])
}

// --- Append-only outreach action log (sent emails, calls, meetings, etc).
//     Foreign tools (Smartlead/Apollo/Gmail) write back via webhook.
model OutreachAction {
  id          BigInt   @id @default(autoincrement())
  npi         String
  physician   Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  channel     String   // "email" | "linkedin" | "call" | "voicemail" | "event" | "note"
  direction   String   // "outbound" | "inbound"
  status      String?  // "sent" | "delivered" | "opened" | "clicked" | "replied" | "bounced" | "failed"
  templateId  String?
  campaignId  String?
  subject     String?
  body        String?
  externalId  String?  // Smartlead/Apollo/Gmail message ID
  payload     Json?

  occurredAt  DateTime @default(now())
  ownerId     String?

  @@index([npi, occurredAt(sort: Desc)])
  @@index([campaignId, occurredAt(sort: Desc)])
}

// --- Trigger-condition-action rules evaluated by scripts/automation:run.
//     Keeps automation pluggable without code changes.
model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  enabled     Boolean  @default(true)

  trigger     Json     // { type: "FACT_ADDED", fieldPath: "academic.recent_publication" } | { type: "STAGE_CHANGED", to: "qualified" } | { type: "SIGNAL_ADDED", kind: "..." } | { type: "CRON", spec: "..." }
  condition   Json     // boolean expression over physician + facts + signals (small DSL)
  action      Json     // { type: "WEBHOOK", url, headers? } | { type: "SET_STAGE", stage } | { type: "ADD_TAG", tag } | { type: "ENROLL_CAMPAIGN", id }

  lastFiredAt DateTime?
  fireCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- CMS-tracked facility (hospital, ASC, etc.) keyed by CCN.
//     Populated by scripts/ingest-facilities.ts from Hospital General
//     Information (CMS) and the ASC list (from POS Files or ASC Quality).
model Facility {
  ccn        String  @id       // 6-char CMS Certification Number
  name       String
  kind       String             // "HOSPITAL" | "ASC" | "LTCH" | "IRF" | "SNF" | "HOME_HEALTH" | "HOSPICE" | "DIALYSIS" | "OTHER"
  address1   String?
  city       String?
  state      String?
  postalCode String?
  ownership  String?            // e.g., "Voluntary non-profit - Private"
  hospitalType String?          // only for kind="HOSPITAL": "Acute Care" | "Critical Access" | ...

  affiliations PhysicianAffiliation[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([kind])
  @@index([state, city])
}

// --- Many-to-many between Physician and Facility. Sourced from CMS
//     "Facility Affiliation" file (Doctors and Clinicians dataset) plus
//     cross-reference to ASC CCNs from POS Files.
model PhysicianAffiliation {
  id        Int      @id @default(autoincrement())
  npi       String
  physician Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)
  ccn       String
  facility  Facility  @relation(fields: [ccn], references: [ccn], onDelete: Cascade)

  // Provenance:
  //   "CMS_FACILITY_AFFILIATION" — direct from CMS Doctors/Clinicians
  //     Facility_Affiliation.csv (high confidence, self-reported).
  //     Only hospitals + post-acute care facilities (LTCH/IRF/SNF/HH/Hospice/Dialysis).
  //   "INFERRED_ZIP_CITY" — inferred from matching physician practice address
  //     to an ASC's city + ZIP (ASCs aren't in the CMS affiliation file).
  source    String

  indPacId  String?   // Ind_PAC_ID from CMS source
  parentCcn String?   // if facility rolls up to a parent

  createdAt DateTime @default(now())

  @@unique([npi, ccn])
  @@index([ccn])
  @@index([source])
}

// --- Lookup table: ZIP5 → CBSA. Populated by scripts/backfill-metros.ts
//     from the Census ZCTA→County + OMB CBSA delineation chain. Used both
//     to backfill existing PhysicianAddress rows and to populate new ones
//     at ingest time.
model ZipMetro {
  zip       String  @id  // 5-digit ZIP
  cbsaCode  String
  cbsaName  String
  cbsaType  String  // "METRO" | "MICRO"

  @@index([cbsaCode])
}

// --- Per-NPI, per-HCPCS, per-year procedure volume from Medicare Physician &
//     Other Practitioners (PUF). We only load rows where HCPCS is in our IR
//     Tier-1 code set, so not every physician has rows and not every CPT.
model ProcedureVolume {
  id               Int       @id @default(autoincrement())
  npi              String
  physician        Physician @relation(fields: [npi], references: [npi], onDelete: Cascade)

  year             Int       // claim year, e.g. 2023
  cpt              String    // HCPCS_Cd, e.g. "37221"
  category         String    // IR category: VASCULAR, EMBOLIZATION, etc.
  placeOfService   String?   // "F" (facility) | "O" (office) | null (unknown)

  totServices      Int       // Tot_Srvcs
  totBenes         Int?      // Tot_Benes, null if CMS suppressed (<11)
  totBeneDaySrvcs  Int?      // Tot_Bene_Day_Srvcs
  avgMdcrAllowed   Float?    // Avg_Mdcr_Alowd_Amt
  avgMdcrPayment   Float?    // Avg_Mdcr_Pymt_Amt

  createdAt        DateTime  @default(now())

  @@unique([npi, year, cpt, placeOfService])
  @@index([npi, year])
  @@index([cpt, year])
  @@index([category, year])
}

// --- Audit log for each bulk ingest run. Lets us see when data was last refreshed
//     and detect silent failures.
model IngestRun {
  id            Int       @id @default(autoincrement())
  source        String    // "NPPES" | "MEDICARE_PUF" | "CARE_COMPARE" | "OPEN_PAYMENTS"
  filename      String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String    // "running" | "completed" | "failed"
  rowsRead      Int       @default(0)
  rowsMatched   Int       @default(0)
  rowsUpserted  Int       @default(0)
  error         String?

  @@index([source, startedAt])
}
